{
  "name": "guesswhatisnext",
  "version": "1.0.0",
  "description": "A browser-based puzzle game where you're shown a sequence of items — emoji, text, or images — that follow a pattern, and you must guess what comes next!",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:load": "npx artillery run tests/load/api-stress.yml",
    "test:load:ws": "npx artillery run tests/load/websocket-stress.yml",
    "test:load:all": "npx artillery run tests/load/api-stress.yml && npx artillery run tests/load/websocket-stress.yml",
    "test:mssql": "node scripts/test-mssql.js",
    "test:all": "vitest run && playwright test",
    "lint": "eslint . --max-warnings 50",
    "dev:full": "node scripts/dev-server.js",
    "dev:log": "node scripts/dev-server.js --no-https"
  },
  "keywords": [
    "game",
    "puzzle",
    "sequence"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@azure/monitor-opentelemetry-exporter": "^1.0.0-beta.32",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mssql": "^12.2.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "eslint": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "vitest": "^4.1.2"
  },
  "optionalDependencies": {
    "artillery": "^2.0.30"
  },
  "engines": {
    "node": ">=20"
  }
}
